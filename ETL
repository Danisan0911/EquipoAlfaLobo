        "import pandas as pd\n",
        "\n",
        "# Cargar el CSV\n",
        "\n",
        "df = pd.read_csv(\"clientes.csv\")\n",
        "\n",
        "print(\"ANTES DE LIMPIEZA:\")\n",
        "print(df)\n",
        "\n",
        "# ------------------------\n",
        "\n",
        "# 1. Eliminar duplicados\n",
        "\n",
        "# ------------------------\n",
        "\n",
        "df = df.drop_duplicates()\n",
        "\n",
        "# ------------------------\n",
        "\n",
        "# 2. Eliminar registros sin nombre\n",
        "\n",
        "# ------------------------\n",
        "\n",
        "df = df.dropna(subset=['nombre'])\n",
        "\n",
        "# ------------------------\n",
        "\n",
        "# 3. Rellenar teléfonos vacíos\n",
        "\n",
        "# ------------------------\n",
        "\n",
        "df['telefono'] = df['telefono'].fillna('0000000000')\n",
        "\n",
        "# ------------------------\n",
        "\n",
        "# 4. Eliminar correos inválidos\n",
        "\n",
        "# ------------------------\n",
        "\n",
        "df = df[df['correo'].str.contains('@', na=False)]\n",
        "\n",
        "# ------------------------\n",
        "\n",
        "# 5. Convertir correos a minúsculas\n",
        "\n",
        "# ------------------------\n",
        "\n",
        "df['correo'] = df['correo'].str.lower()\n",
        "\n",
        "print(\"\\nDESPUÉS DE LIMPIEZA:\")\n",
        "print(df)\n"
      ],
